# Copy to .env for local development (never commit the real .env).

# Supabase (project: OB FAQ)
SUPABASE_URL=https://fjsogozwseqoxgddjeig.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Вход в приложение — ТОЛЬКО по личному коду из таблицы public.login_codes
# (employee_id + can_see_all). Никаких секретов в браузер не попадает.
#   * Обычный код (can_see_all=false) = бухгалтер: под обязательным разбором тикетов.
#   * Код с can_see_all=true = менеджер/админ: единственный обход гейта.
# Для проверки кодов нужен SUPABASE_SERVICE_ROLE_KEY. Если он не задан — вход
# отключён (только локальная разработка; в продакшене задавать обязательно).
#
# ACCESS_PASSWORD БОЛЬШЕ НЕ ДАЁТ ВХОД и не обходит гейт. Оставлен только как
# необязательный источник секрета подписи сессии (если задан).
# ACCESS_PASSWORD=unused-for-login
# Необязательно: свой секрет подписи сессии. По умолчанию выводится из
# ACCESS_PASSWORD, иначе из SUPABASE_SERVICE_ROLE_KEY.
# SESSION_SECRET=some-long-random-string

# Telegram daily summary (бот, который постит короткую сводку)
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Telegram user-account (MTProto) — вход по НОМЕРУ ТЕЛЕФОНА, не через бота.
# Нужно, чтобы читать ПОЛНЫЙ список участников групп (бот так не умеет) и чинить
# ложные «нет ответственного». api_id / api_hash берутся на my.telegram.org
# (Login → API development tools → Create application).
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your-api-hash
# Строка сессии (полный доступ к аккаунту — секрет!). Получить одним из способов:
#   • локально:            npm run telegram-login
#   • в браузере на Render: включить TELEGRAM_LOGIN_ENABLED=1 и открыть /telegram-login
# TELEGRAM_SESSION=1Bx...long-session-string...
# Временно включает страницу входа /telegram-login на дашборде (для Render).
# Держите её включённой ТОЛЬКО на время получения сессии, потом уберите.
# TELEGRAM_LOGIN_ENABLED=1
# По умолчанию присутствие пишется только для активных чатов из public.chats;
# SYNC_ALL_CHATS=1 — писать для всех групп аккаунта; SYNC_CHAT_LIMIT=N — для отладки.
# SYNC_ALL_CHATS=0
# SYNC_CHAT_LIMIT=5

# Public URL of the deployed dashboard (goes into the Telegram message)
PLATFORM_URL=https://ob-chat-checklist-dashboard.onrender.com

# Web server port (Render sets this automatically)
PORT=3000

# Исключение тестовых чатов (по умолчанию включено, шаблон "^test").
# EXCLUDE_TEST_CHATS=0            # показать вообще все чаты
# TEST_CHAT_PATTERN=^(test|qa)-  # свой шаблон распознавания тестовых

# Set DRY_RUN=1 to print the daily message instead of sending it
# DRY_RUN=1

# Необязательно: файл состояния для идемпотентности ежедневной сводки
# (не слать повторно, если за сегодня уже отправляли).
# REPORT_STATE_FILE=.report-state.json
