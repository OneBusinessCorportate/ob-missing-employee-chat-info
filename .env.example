# Copy to .env for local development (never commit the real .env).

# Supabase (project: OB FAQ)
SUPABASE_URL=https://fjsogozwseqoxgddjeig.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Доступ к дашборду по общему паролю. Если не задан — вход отключён
# (только для локальной разработки; в продакшене задавать обязательно).
ACCESS_PASSWORD=choose-a-shared-password
# Необязательно: свой секрет подписи сессии (по умолчанию выводится из пароля).
# SESSION_SECRET=some-long-random-string

# Telegram daily summary
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Public URL of the deployed dashboard (goes into the Telegram message)
PLATFORM_URL=https://ob-chat-checklist-dashboard.onrender.com

# Web server port (Render sets this automatically)
PORT=3000

# Исключение тестовых чатов (по умолчанию включено, шаблон "^test").
# EXCLUDE_TEST_CHATS=0            # показать вообще все чаты
# TEST_CHAT_PATTERN=^(test|qa)-  # свой шаблон распознавания тестовых

# Set DRY_RUN=1 to print the daily message instead of sending it
# DRY_RUN=1

# Необязательно: файл состояния для идемпотентности ежедневной сводки
# (не слать повторно, если за сегодня уже отправляли).
# REPORT_STATE_FILE=.report-state.json
