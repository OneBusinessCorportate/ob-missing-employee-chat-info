# Copy to .env for local development (never commit the real .env).

# Supabase (project: OB FAQ)
SUPABASE_URL=https://fjsogozwseqoxgddjeig.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram daily summary
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Public URL of the deployed dashboard (goes into the Telegram message)
PLATFORM_URL=https://ob-chat-checklist-dashboard.onrender.com

# Web server port (Render sets this automatically)
PORT=3000

# Set DRY_RUN=1 to print the daily message instead of sending it
# DRY_RUN=1
